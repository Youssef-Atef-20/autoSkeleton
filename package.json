    "build": "vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "react",
    "skeleton",
    "loader",
    "react-skeleton",
    "ui",
    "loading",
    "autoskeleton"
  ],
  "author": "Youssef Atef",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Youssef-Atef-20/autoSkeleton.git"
  },
  "homepage": "https://github.com/Youssef-Atef-20/autoSkeleton#readme",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "dependencies": {
    "vite": "^5.4.21"
  }
